# FitMe AI — Test/staging environment
# Copy: cp .env.test.example .env.test  then edit values before deploy

# Public URL users open in browser (include port if not 80/443)
# Local test:  http://localhost:3000
# LAN / VPS:   http://YOUR_SERVER_IP:3000
PUBLIC_APP_URL=http://localhost:3000

# App port exposed on host
APP_PORT=3000

# Optional: expose backend API on host (only with profile debug-api)
API_PORT=8080

# Database — change password for any shared test server
POSTGRES_DB=fitme
POSTGRES_USER=fitme
POSTGRES_PASSWORD=change-me-test-db-password

# JWT — generate a long random string (min 32 chars); must match backend AND frontend Docker
JWT_SECRET=change-me-test-jwt-secret-min-256-bits-long-random-string

# Demo seed data on first start (admin/brand/user @fitme.ai)
FITME_SEED_ENABLED=true
FITME_SEED_PASSWORD=fitme123
