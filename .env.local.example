# FitMe AI — Local pre-deploy (test AI trước khi push Vercel/Render)
# Copy: cp .env.local.example .env.local  (Windows: copy .env.local.example .env.local)
# Start:  .\scripts\dev-local.ps1   hoặc   ./scripts/dev-local.sh
# Docs:   docs/LOCAL_AI_DEV.md

# ── App URLs (giống production: FE proxy → BE) ─────────────────
PUBLIC_APP_URL=http://localhost:3000
APP_PORT=3000
API_PORT=8080

# Postgres host port (5433 tránh trùng docker compose mặc định trên 5432)
POSTGRES_PORT=5433

# ── Database ───────────────────────────────────────────────────
POSTGRES_DB=fitme
POSTGRES_USER=fitme
POSTGRES_PASSWORD=fitme123
DB_URL=jdbc:postgresql://localhost:5433/fitme
DB_USERNAME=fitme
DB_PASSWORD=fitme123

# ── Auth ───────────────────────────────────────────────────────
JWT_SECRET=fitme-local-dev-secret-min-256-bits-change-me-please
JWT_ACCESS_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# ── Backend ────────────────────────────────────────────────────
SERVER_PORT=8080
UPLOAD_DIR=./uploads
CORS_ORIGINS=http://localhost:3000

# Seed demo data (admin/brand/user @fitme.ai)
FITME_SEED_ENABLED=true
FITME_SEED_TOP_UP=true
FITME_SEED_PASSWORD=fitme123
FITME_SEED_PRODUCTS_PER_BRAND=18
FITME_SEED_MIN_ACTIVE_PRODUCTS=36
FITME_SEED_FASHION_REFRESH=true

# Frontend proxy (Next.js rewrite)
NEXT_PUBLIC_API_URL=/api/v1
BACKEND_INTERNAL_URL=http://localhost:8080

# PayOS — mock trên local
PAYOS_MOCK=true
PAYOS_RETURN_URL=http://localhost:3000/brand/billing/return?status=success
PAYOS_CANCEL_URL=http://localhost:3000/brand/billing/return?status=cancel

# ── AI Stylist (Gemini) — mirror Render production ─────────────
# Bật: điền GEMINI_API_KEY từ https://aistudio.google.com/apikey
FITME_AI_STYLIST_MODE=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_CANDIDATE_LIMIT=30
GEMINI_TIMEOUT_MS=15000

# ── Virtual Try-On (ai-vton microservice) ──────────────────────
# mock = preview nhanh, không gọi HF
# hf     = IDM-VTON qua Hugging Face (cần HF_TOKEN)
FITME_AI_MODE=mock
HF_TOKEN=
HF_SPACE=yisol/IDM-VTON
AI_VTON_URL=http://localhost:8001
FITME_PUBLIC_BASE_URL=http://localhost:8080
FITME_AI_POLL_INTERVAL_MS=3000
FITME_AI_JOB_TIMEOUT_SECONDS=120
