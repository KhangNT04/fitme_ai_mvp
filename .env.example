# Database
POSTGRES_DB=fitme
POSTGRES_USER=fitme
POSTGRES_PASSWORD=fitme123
DB_URL=jdbc:postgresql://localhost:5432/fitme
DB_USERNAME=fitme
DB_PASSWORD=fitme123

# JWT
JWT_SECRET=fitme-dev-secret-change-in-production-min-256-bits-long-key-here
JWT_ACCESS_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# Backend
SERVER_PORT=8080
UPLOAD_DIR=./uploads
CORS_ORIGINS=http://localhost:3000

# Demo seed (backend startup)
FITME_SEED_ENABLED=true
FITME_SEED_TOP_UP=true
FITME_SEED_PRODUCTS_PER_BRAND=18
FITME_SEED_MIN_ACTIVE_PRODUCTS=36
FITME_SEED_FASHION_REFRESH=true

# Frontend — same-origin proxy via Next.js rewrite (see frontend/next.config.ts)
NEXT_PUBLIC_API_URL=/api/v1

# PayOS (brand billing) — đặt key thật trong file .env (không commit)
PAYOS_MOCK=true
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_RETURN_URL=http://localhost:3000/brand/billing/return?status=success
PAYOS_CANCEL_URL=http://localhost:3000/brand/billing/return?status=cancel
